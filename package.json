{
  "name": "yt2ctx",
  "version": "1.0.0",
  "description": "Turn YouTube videos into timed transcripts and representative frame packs for VLM context.",
  "type": "module",
  "bin": {
    "yt2ctx": "./dist/cli.js",
    "yt2ctx-mcp": "./dist/mcp.js"
  },
  "main": "dist/index.js",
  "scripts": {
    "dev": "next dev",
    "build": "node scripts/install-ytdlp-standalone.mjs && tsc --noEmit && next build && npm run build:bin",
    "build:bin": "tsup src/cli.ts src/mcp.ts src/index.ts --format esm --out-dir dist --target node20 --platform node --clean",
    "cli": "tsx src/cli.ts",
    "mcp": "tsx src/mcp.ts",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "stripe:instruments:dev": "node scripts/create-stripe-instruments.mjs",
    "stripe:instruments:prod": "node scripts/create-stripe-instruments.mjs --prod"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JacobFV/yt2ctx.git"
  },
  "keywords": [
    "youtube",
    "transcription",
    "vision",
    "mcp",
    "openai"
  ],
  "author": "",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/JacobFV/yt2ctx/issues"
  },
  "homepage": "https://github.com/JacobFV/yt2ctx#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@neondatabase/serverless": "^1.1.0",
    "@vercel/blob": "^2.4.0",
    "commander": "^14.0.3",
    "dotenv": "^17.4.2",
    "ffmpeg-static": "^5.3.0",
    "ffprobe-static": "^3.1.0",
    "jszip": "^3.10.1",
    "next": "^16.2.6",
    "openai": "^6.38.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "sharp": "^0.34.5",
    "stripe": "^22.1.1",
    "youtube-dl-exec": "^3.1.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/ffprobe-static": "^2.0.3",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "eslint": "^10.4.0",
    "eslint-config-next": "^16.2.6",
    "tsup": "^8.5.1",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "postcss": "^8.5.10"
  }
}
